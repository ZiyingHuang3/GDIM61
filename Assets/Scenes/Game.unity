--- !u!114 &315668208
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 315668204}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3127790790c71441cbdc8d59dd2ead68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  isIntroDialogue: 0
  nodes:
  - speaker: 0
    speakerName: Hazel
    dialogueText: Who are you?
    hasChoices: 0
    choices: []
    nextNodeIndex: 1
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: ...
    hasChoices: 0
    choices: []
    nextNodeIndex: 2
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: (Shoked) You can see me?
    hasChoices: 0
    choices: []
    nextNodeIndex: 3
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Yes. Do you still remember anything?
    hasChoices: 0
    choices: []
    nextNodeIndex: 4
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: (Frown) Not sure. My memory is fragment.
    hasChoices: 0
    choices: []
    nextNodeIndex: 5
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: (Frown) Not sure. My memory is fragment.
    hasChoices: 0
    choices: []
    nextNodeIndex: 6
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Do you remember anyone who came over?
    hasChoices: 0
    choices: []
    nextNodeIndex: 7
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: My suppoeter Will. assistant Merlin , and guest Monica.
    hasChoices: 0
    choices: []
    nextNodeIndex: 8
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Who do you suspect?
    hasChoices: 0
    choices: []
    nextNodeIndex: 9
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: (Dejected) They all don't like me.
    hasChoices: 0
    choices: []
    nextNodeIndex: 10
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Perhaps could ask some questions.
    hasChoices: 1
    choices:
    - choiceText: Will
      nextNodeIndex: 11
      requiredEvidence: {fileID: 0}
    - choiceText: Merilin
      nextNodeIndex: 13
      requiredEvidence: {fileID: 0}
    - choiceText: Monica
      nextNodeIndex: 15
      requiredEvidence: {fileID: 0}
    nextNodeIndex: 17
    afterAllChoicesNextNode: 17
  - speaker: 0
    speakerName: Hazel
    dialogueText: Why? Isn't Wiill your supporter? He has been by your side all along.
    hasChoices: 0
    choices: []
    nextNodeIndex: 12
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: He has ever trusted me. He is a very cautious person
    hasChoices: 0
    choices: []
    nextNodeIndex: 10
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Merlin
    dialogueText: What do you think of Merlin, he is your assistant
    hasChoices: 0
    choices: []
    nextNodeIndex: 14
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: 'He has always had a grudge against me. '
    hasChoices: 0
    choices: []
    nextNodeIndex: 18
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Was it you who invited Monica?
    hasChoices: 0
    choices: []
    nextNodeIndex: 16
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: She came by herself. She wanted me to delete the blog about her.
      The revealed truth was too much for her to accept.
    hasChoices: 0
    choices: []
    nextNodeIndex: 10
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: It seems there's nothing more to say. Maybe I can find something
      to trigger some memories in him.
    hasChoices: 0
    choices: []
    nextNodeIndex: -1
    afterAllChoicesNextNode: -1
  - speaker: 1
    speakerName: Bob
    dialogueText: He always thinks I have too many responsibilities, but I merely
      ask him to do his part of the job.
    hasChoices: 0
    choices: []
    nextNodeIndex: 10
    afterAllChoicesNextNode: -1
