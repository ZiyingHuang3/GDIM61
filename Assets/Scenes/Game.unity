  - speaker: 0
    speakerName: Hazel
    dialogueText: What did they comr for?
    hasChoices: 0
    choices: []
    nextNodeIndex: 8
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: (motionally agitated) They wanted to kill me!
    hasChoices: 0
    choices: []
    nextNodeIndex: 9
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: (mentally) Let's change the topic.
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: You had an argument with the guest.
    hasChoices: 0
    choices: []
    nextNodeIndex: 11
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: She wanted me to shut up
    hasChoices: 0
    choices: []
    nextNodeIndex: 12
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Why?
    hasChoices: 0
    choices: []
    nextNodeIndex: 13
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: She thinks my radio station has affected her.
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: How come this pen hasn't been thrown away yet when it has no ink?
    hasChoices: 0
    choices: []
    nextNodeIndex: 15
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: I' ve used it.
    hasChoices: 0
    choices: []
    nextNodeIndex: 16
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: For waht?
    hasChoices: 0
    choices: []
    nextNodeIndex: 17
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: ...
    hasChoices: 0
