--- !u!114 &771541057
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 771541056}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3127790790c71441cbdc8d59dd2ead68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  isIntroDialogue: 0
  nodes:
  - speaker: 1
    speakerName: Bob
    dialogueText: What do you want to ask me?
    hasChoices: 1
    choices:
    - choiceText: Coffee
      nextNodeIndex: 1
      requiredEvidence: {fileID: 11400000, guid: 008a7bf8d99b35f499d46914543c2fc5, type: 2}
    - choiceText: Entry and Exit Record
      nextNodeIndex: 5
      requiredEvidence: {fileID: 11400000, guid: 3c0efdfe216cdd84ea8a27e1d04dbcc8, type: 2}
    - choiceText: Chat record with Monica
      nextNodeIndex: 10
      requiredEvidence: {fileID: 11400000, guid: 1795d49ff1d0fa94c94d7c824ddc4b93, type: 2}
    - choiceText: A pen withou ink
      nextNodeIndex: 14
      requiredEvidence: {fileID: 11400000, guid: 573f5389f7a6d07498dc859c40fc39e6, type: 2}
    nextNodeIndex: 0
    afterAllChoicesNextNode: -1
  - speaker: 0
    speakerName: Hazel
    dialogueText: Do you usually drink coffee while recording?
    hasChoices: 0
    choices: []
    nextNodeIndex: 2
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: Somethimes I get very sleepy when recording late into the night.
    hasChoices: 0
    choices: []
    nextNodeIndex: 3
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Who usually gives you coffee?
    hasChoices: 0
    choices: []
    nextNodeIndex: 4
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: Merlin.
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Were there any other people bsides these three who came?
    hasChoices: 0
    choices: []
    nextNodeIndex: 6
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: No
    hasChoices: 0
    choices: []
    nextNodeIndex: 7
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: What did they come for?
    hasChoices: 0
    choices: []
    nextNodeIndex: 8
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: (motionally agitated) They wanted to kill me!
    hasChoices: 0
    choices: []
    nextNodeIndex: 9
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: (mentally) Let's change the topic.
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: You had an argument with Monica.
    hasChoices: 0
    choices: []
    nextNodeIndex: 11
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: She wanted me to shut up.
    hasChoices: 0
    choices: []
    nextNodeIndex: 12
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Why?
    hasChoices: 0
    choices: []
    nextNodeIndex: 13
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: She thinks my podcast has affected her.
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: How come this pen hasn't been thrown away yet when it has no ink?
    hasChoices: 0
    choices: []
    nextNodeIndex: 15
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: I' ve used it.
    hasChoices: 0
    choices: []
    nextNodeIndex: 16
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: For waht?
    hasChoices: 0
    choices: []
    nextNodeIndex: 17
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Bob
    dialogueText: ...
    hasChoices: 0
    choices: []
    nextNodeIndex: 0
    afterAllChoicesNextNode: 0
