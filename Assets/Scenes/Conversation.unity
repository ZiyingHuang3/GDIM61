--- !u!114 &42722361
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 42722359}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3127790790c71441cbdc8d59dd2ead68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  isIntroDialogue: 0
  nodes:
  - speaker: 0
    speakerName: Hazel
    dialogueText: Mr. Merlin, may I ask what you did in the recording studio at 19:17?
    hasChoices: 0
    choices: []
    nextNodeIndex: 1
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: (Shifting his gaze away) Mr. Bob needs to do some preparations
      before the recording.
    hasChoices: 0
    choices: []
    nextNodeIndex: 2
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: ' I''ll go and help him sort out the materials.'
    hasChoices: 0
    choices: []
    nextNodeIndex: 3
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Is there nothing else?
    hasChoices: 0
    choices: []
    nextNodeIndex: 4
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: No more...
    hasChoices: 0
    choices: []
    nextNodeIndex: 5
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: No more...
    hasChoices: 0
    choices: []
    nextNodeIndex: 6
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: What kind of person do you think Mr. Bob is?
    hasChoices: 0
    choices: []
    nextNodeIndex: 7
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: He is very demanding and extremely picky.
    hasChoices: 0
    choices: []
    nextNodeIndex: 8
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: But everyone believes that he is a good person.
    hasChoices: 0
    choices: []
    nextNodeIndex: 9
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: These two are not in conflict.
    hasChoices: 0
    choices: []
    nextNodeIndex: 10
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: (Out of sight) ...
    hasChoices: 0
    choices: []
    nextNodeIndex: 11
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: What about Mr. Will?
    hasChoices: 0
    choices: []
    nextNodeIndex: 12
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: 'He is a very gentle person. '
    hasChoices: 0
    choices: []
    nextNodeIndex: 13
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: Bob believes that I always make mistakes in my work, and Mr. Will
      always comforts me.
    hasChoices: 0
    choices: []
    nextNodeIndex: 14
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: OK. Thank you very much.
    hasChoices: 0
    choices: []
    nextNodeIndex: -1
    afterAllChoicesNextNode: 0
