MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 320073177}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3127790790c71441cbdc8d59dd2ead68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  isIntroDialogue: 0
  nodes:
  - speaker: 0
    speakerName: Hazel
    dialogueText: 'Miss Merlin, you entered the recording studio at 19:00. '
    hasChoices: 0
    choices: []
    nextNodeIndex: 1
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: 'As far as I know, you were not invited. '
    hasChoices: 0
    choices: []
    nextNodeIndex: 2
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Could you please tell me what you were looking for Bob for?
    hasChoices: 0
    choices: []
    nextNodeIndex: 3
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: I hope he can clarify what he said in the previous radio program.
    hasChoices: 0
    choices: []
    nextNodeIndex: 4
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: Could you ask him what he said that made you so angry?
    hasChoices: 0
    choices: []
    nextNodeIndex: 6
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: 'I will investigate this matter later. '
    hasChoices: 0
    choices: []
    nextNodeIndex: 7
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: His smear campaign against me caused me to lose my job.
    hasChoices: 0
    choices: []
    nextNodeIndex: 5
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: What did you do in the recording studio for those eleven minutes?
    hasChoices: 0
    choices: []
    nextNodeIndex: 8
    afterAllChoicesNextNode: 0
  - speaker: 0
    speakerName: Hazel
    dialogueText: What did you do in the recording studio for those eleven minutes?
    hasChoices: 0
    choices: []
    nextNodeIndex: 9
    afterAllChoicesNextNode: 0
  - speaker: 1
    speakerName: Merlin
    dialogueText: He refused to admit his mistakes, and we had a quarrel but it ended
      without any resolution.
    hasChoices: 0
    choices: []
    nextNodeIndex: -1
    afterAllChoicesNextNode: 0
